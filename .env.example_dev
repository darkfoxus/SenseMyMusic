# Project
COMPOSE_PROJECT_NAME=sensemymusic-dev

# Laravel app
APP_NAME="Sense My Music"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
UID=1000
GID=1000

# PostgreSQL
POSTGRES_USER=sensemymusic
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sensemymusic

# Ports
BACKEND_PORT=8080
POSTGRES_PORT=5432

# Set to true on first run to seed the database, then back to false
RUN_SEEDER=false

# Future
JWT_SECRET=replace_me
OPENAI_API_KEY=